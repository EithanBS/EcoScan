# HELIXMIND_API_KEY: Required for HelixMind API access.
HELIXMIND_API_KEY="YOUR_HELIXMIND_API_KEY"

# Optional overrides. Keep defaults unless you have a custom HelixMind deployment.
HELIXMIND_BASE_URL="https://helixmind.online/v1"
HELIXMIND_CHAT_URL="https://helixmind.online/v1/chat/completions"
HELIXMIND_IMAGES_URL="https://helixmind.online/v1/images/generations"
HELIXMIND_AUDIO_URL="https://helixmind.online/v1/audio/speech"

# Model used by HydroScan and PlantScan analysis.
HELIXMIND_MODEL="gemini-3-flash-preview"
